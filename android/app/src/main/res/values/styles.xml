<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 
      Theme applied to the Android Window while the process is starting.
      This theme is responsible for the "double splash screen" issue.
    -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <!-- Show a solid background color instead of the app icon -->
        <item name="android:windowBackground">@color/splash_background_color</item>
        <item name="android:forceDarkAllowed">false</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">false</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>
    <!-- Theme applied to the Flutter Window after the Flutter UI initializes -->
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
